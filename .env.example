# Set PALLEX_MOCK=true to run entirely on the MSW mock (no Pall-Ex credentials needed)
PALLEX_MOCK=true
PALLEX_BASE_URL=https://nexus.pallex.com/api
PALLEX_USERNAME=
PALLEX_PASSWORD=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin dashboard auth — required, no defaults (see src/lib/env.ts)
# DASHBOARD_PASSWORD: shared staff password (min 8 chars)
# DASHBOARD_SESSION_SECRET: random secret for signing session cookies (min 32 chars)
# Generate with: openssl rand -base64 32
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_SECRET=
